NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project. For the first APAC deployment, create the project in Singapore.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage buckets used by the generation workflow.
SUPABASE_SOURCE_IMAGE_BUCKET=source-images
SUPABASE_FRONT_IMAGE_BUCKET=front-images
SUPABASE_ACTION_VIDEO_BUCKET=action-videos
SUPABASE_ASSET_BUNDLE_BUCKET=asset-bundles

# Future providers. Keep these only on the server.
OPENAI_API_KEY=

# Volcengine Ark / JiMeng video generation. ARK_API_KEY is also accepted.
JIMENG_API_KEY=
JIMENG_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
JIMENG_QUERY_URL_TEMPLATE=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks/{taskId}
JIMENG_VIDEO_MODEL=doubao-seedance-2-0-fast-260128
JIMENG_VIDEO_DURATION_SECONDS=10
JIMENG_VIDEO_RESOLUTION=720p
JIMENG_VIDEO_FRAMES_PER_SECOND=24
JIMENG_VIDEO_WATERMARK=false
