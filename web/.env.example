NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_SOURCE_IMAGE_BUCKET=source-images
SUPABASE_FRONT_IMAGE_BUCKET=front-images
SUPABASE_ACTION_VIDEO_BUCKET=action-videos
SUPABASE_ASSET_BUNDLE_BUCKET=asset-bundles

# Optional starter cat seeded for newly registered users.
STARTER_CAT_NAME=体验猫
STARTER_CAT_IMAGE_URL=
STARTER_CAT_IDLE_LOOP_VIDEO_URL=
STARTER_CAT_SLEEP_LOOP_VIDEO_URL=
STARTER_CAT_CATCH_BUG_VIDEO_URL=
STARTER_CAT_CLICK_REACT_VIDEO_URL=
# Alternative compact form: {"idle_loop":"https://...","sleep_loop":"https://..."}
STARTER_CAT_ASSET_URLS_JSON=

# Comma-separated admin emails accepted in addition to Supabase app_metadata.role=admin.
ADMIN_EMAILS=

# Optional signing secret for local/mock preview login cookies.
AUTH_MOCK_COOKIE_SECRET=

# Server-only Volcengine Ark / Seedance provider keys. Fast is the default model
# for production; mini_API_KEY is only used when the mini model has API access.
mini_API_KEY=
ARK_API_KEY=
JIMENG_API_KEY=
JIMENG_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
JIMENG_QUERY_URL_TEMPLATE=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks/{taskId}
JIMENG_VIDEO_MODEL=doubao-seedance-2-0-fast-260128
GENERATION_JOB_TIMEOUT_SECONDS=1800
GENERATION_JOB_RECOVERY_WINDOW_SECONDS=86400
